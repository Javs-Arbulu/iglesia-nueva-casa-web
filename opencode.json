{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md", "CODEBASE.md"],
  "formatter": {
    "prettier": {
      "command": ["npx", "prettier", "--write", "$FILE"],
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".json", ".css", ".md"]
    }
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "public/**"]
  }
}
